---
import BasePage from '../layouts/BasePage.astro';
import Container from '../components/Container.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';

export interface Props {
  title: string
  description: string
  permalink: string
  tab?: string
}

let { title, description, permalink, tab, content } = Astro.props;

let postTitle

if (content !== undefined) {
  title = content.title
  postTitle = title
  description = content.description
  permalink = content.permalink
  
  if (content.tab !== undefined) {
    tab = content.tab
  } else {
    tab = title
  }
} else {
  if (tab === undefined) {
    tab = title
  }
}
---

<style>
  

  .main-content {
    @apply w-full px-4 xl:px-0 lg:w-3/4 min-h-screen;
  }
</style>

<BasePage title={title} description={description} permalink={permalink}>
  <Header tab={tab}/>

  <Container>
    <Sidebar />
    <div class="main-content">
      {postTitle !== undefined && <h1>{postTitle}</h1>}
    <slot />
    
    </div>
  </Container>

  <Footer/>
</BasePage>